PI_MCP_URL=http://M1-S1.local:8765/mcp
PI_MCP_TOKEN=your-bearer-token-here

# code-graph MCP server (separate from docs server). On the M1-S1 box the
# mcp-code-graph extension auto-reads ~/.config/code-graph/mcp-token if
# PI_CODE_GRAPH_TOKEN is empty, so the loopback case works without
# manual setup. Override these when pi runs on a different host.
PI_CODE_GRAPH_URL=http://127.0.0.1:4753/mcp
PI_CODE_GRAPH_TOKEN=

SEARXNG_URL=http://M1-S1.lan:8888
